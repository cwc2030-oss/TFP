generator client {
  provider      = "prisma-client-js"
  output        = "/home/ubuntu/terra_firma_mapping/nextjs_space/node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  company      String?
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model MapLayer {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  source      String?
  category    String?
  isAvailable Boolean  @default(true)
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String   @id @default(cuid())
  userId          String?
  parcelAddress   String
  parcelLat       Float
  parcelLng       Float
  parcelId        String?
  selectedLayers  String   @default("[]")
  guestEmail      String?
  status          String   @default("pending")
  paymentStatus   String   @default("pending")
  paymentIntentId String?
  stripeSessionId String?
  pdfPath         String?
  price           Float    @default(350)
  productType     String   @default("full_report")
  terrainData     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id])
}

model Lead {
  id        String   @id @default(cuid())
  email     String
  parcelId  String?
  address   String?
  source    String   @default("email_parcel")
  createdAt DateTime @default(now())
  
  @@index([email])
}

model FunnelEvent {
  id        String   @id @default(cuid())
  event     String   // address_search, terrain_analyzer_opened, pricing_page_viewed, checkout_initiated, purchase_completed
  address   String?
  metadata  String?  // JSON: productType, price, orderId, lat, lng, etc.
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}

model ParcelCache {
  id          String   @id @default(cuid())
  lat         Float
  lng         Float
  data        String   // JSON stringified parcel data
  createdAt   DateTime @default(now())
  expiresAt   DateTime // Cache expiration (e.g., 30 days)
  
  @@unique([lat, lng])
  @@index([lat, lng])
}
