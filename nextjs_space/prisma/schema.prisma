generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/terra_firma_mapping/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  company      String?
  role         String   @default("user")
  termsAcceptedAt DateTime?
  termsVersion    String?
  privacyVersion  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders           Order[]
  savedProperties  SavedProperty[]
  parcelPurchases  ParcelPurchase[]
  listings         Listing[]
  inquiries        Inquiry[]
  huntingReports   HuntingReport[]
  standSelections  StandSelection[]
  huntSessions     HuntSession[]
  parcelReads      ParcelRead[]

  // Brick 1 — vetted-introduction marketplace (gated: TFP_HUNTER_PROFILES_OPEN)
  hunterProfile    HunterProfile?     // one trust profile per user (hunter side)
  ownerShortlists  HunterShortlist[]  // hunters this user (as landowner) has shortlisted

  // Landowner path — parcels this user has claimed as their own (see ParcelClaim).
  parcelClaims     ParcelClaim[]

  // Piece 6a: placeholder Season Pass unlock (kept as a legacy/admin override).
  // When true, the user has unlimited Terrain Brain reads + save. Pro/Pro Max/admin
  // are treated as unlocked in code regardless of this flag.
  readsUnlocked        Boolean  @default(false)

  // Piece 6b: real Season Pass ($19 one-time, seasonal). Set by the Stripe webhook
  // on a completed season_pass checkout. seasonPassSeason holds the season bucket
  // the pass is valid for (e.g. "2026"); seasonPassExpiry is when it lapses. A pass
  // grants unlimited reads + save ONLY while seasonPassSeason == current season and
  // now < seasonPassExpiry (see lib/reads.isReadsUnlocked). 6c uses these fields.
  seasonPassSeason     String?
  seasonPassExpiry     DateTime?

  // Stripe subscription fields
  stripeCustomerId     String?   @unique
  stripePriceId        String?
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String?   @default("free")
  subscriptionEnds     DateTime?
}

// Piece 6a — Terrain Brain free-read meter.
// One row per DISTINCT parcel/scope a user has read (fully analyzed) in a season.
// A "read" = the first full Terrain Brain flow analysis of a distinct parcel.
// Revisiting an already-read parcel does NOT create a new row (unique key), so it
// never consumes another read. Season string comes from lib/reads.ts getCurrentSeason().
model ParcelRead {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcelKey  String                    // Regrid parcelId when available, else "ll:lat,lng"
  season     String                    // e.g. "2026" — hunting season bucket
  address    String?
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())

  @@unique([userId, parcelKey, season])
  @@index([userId, season])
}

// ============================================================================
// Landowner path — "Claim your parcel".
//
// A claim is the landowner signal: a user asserts a parcel is THEIRS. On claim
// we soft-verify by matching the signed-in user's name against the Regrid
// owner-of-record for that parcel (light name match — NOT a hard legal check).
//
//   ownerMatchStatus:
//     MATCHED  — the name matched the Regrid owner-of-record (soft-verified).
//                Their OWN parcels always read free + are flagged `listable`.
//     PENDING  — no clean match (owner-of-record is an LLC/trust, or the name
//                differs). We do NOT silently grant free/listable; the UI shows
//                "pending verification."
//
// HONESTY (mirrors CredentialLevel + the terrain verdict): a soft match is NOT
// "Verified Owner." We never display an ownership badge beyond what we checked.
// Hard ownership verification is REQUIRED before listing / any money (reuse this
// record, tightened) — enforced downstream, never granted here.
//
// Meter scoping (what protects the $39 tier): a MATCHED claim exempts ONLY that
// parcel from the read meter. Scouting anyone else's ground still runs the meter
// — free == your own land only.
// ============================================================================
model ParcelClaim {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Same key convention as ParcelRead: Regrid parcelId when available, else
  // "ll:lat,lng". This is what the meter checks for an ownership exemption.
  parcelKey         String
  ownerMatchStatus  OwnerMatchStatus @default(PENDING)
  // Snapshot of the Regrid owner-of-record at claim time, and the name we
  // matched against — kept for the tightened hard-verify step before listing.
  regridOwnerName   String?
  claimantName      String?
  // Flagged true ONLY on a MATCHED claim: eligible to list when the marketplace
  // opens (still gated on hard verification before any money).
  listable          Boolean  @default(false)
  // Parcel context for My Parcels display + the hard-verify step.
  address           String?
  lat               Float?
  lng               Float?
  acreage           Float?
  claimedAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, parcelKey])
  @@index([userId])
  @@index([parcelKey])
}

enum OwnerMatchStatus {
  PENDING
  MATCHED
}

model MapLayer {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  source      String?
  category    String?
  isAvailable Boolean  @default(true)
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String   @id @default(cuid())
  userId          String?
  parcelAddress   String
  parcelLat       Float
  parcelLng       Float
  parcelId        String?
  selectedLayers  String   @default("[]")
  guestEmail      String?
  status          String   @default("pending")
  paymentStatus   String   @default("pending")
  paymentIntentId String?
  stripeSessionId String?
  pdfPath         String?
  price           Float    @default(350)
  productType     String   @default("full_report")
  terrainData     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id])
}

model Lead {
  id             String   @id @default(cuid())
  email          String
  parcelId       String?
  address        String?
  lat            Float?
  lng            Float?
  county         String?
  state          String?
  teaserScore    Int?              // Flow index shown in the free teaser
  source         String   @default("email_parcel")
  alertCounty    Boolean  @default(false)  // "Notify me about new leases in my county"
  convertedAt    DateTime?         // Set when a paid purchase is linked
  createdAt      DateTime @default(now())

  purchases      ParcelPurchase[]
  
  @@index([email])
  @@index([county, state])
}

model FunnelEvent {
  id        String   @id @default(cuid())
  event     String   // address_search, terrain_analyzer_opened, pricing_page_viewed, checkout_initiated, purchase_completed
  address   String?
  metadata  String?  // JSON: productType, price, orderId, lat, lng, etc.
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}

model ParcelCache {
  id          String   @id @default(cuid())
  lat         Float
  lng         Float
  data        String   // JSON stringified parcel data
  createdAt   DateTime @default(now())
  expiresAt   DateTime // Cache expiration (e.g., 30 days)
  
  @@unique([lat, lng])
  @@index([lat, lng])
}

model NeighborCache {
  id          String   @id @default(cuid())
  lat         Float
  lng         Float
  radius      Int      @default(500)
  data        String   // JSON stringified array of neighbor parcels
  createdAt   DateTime @default(now())

  @@unique([lat, lng, radius])
  @@index([lat, lng])
}

// Cache for the parcels-adjacent-v2 Regrid endpoint. Kept separate from
// NeighborCache because it stores a different response shape (AdjacentParcel[])
// and shares the same default radius (500), which would otherwise collide.
model AdjacentCache {
  id          String   @id @default(cuid())
  lat         Float
  lng         Float
  radius      Int      @default(500)
  data        String   // JSON stringified AdjacentResponse
  createdAt   DateTime @default(now())

  @@unique([lat, lng, radius])
  @@index([lat, lng])
}

model RegridUsage {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  endpointTag String
  callCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, endpointTag])
  @@index([date])
}

// Cache-hit instrumentation. Kept separate from RegridUsage so the Regrid
// daily-alert total is never inflated by cache hits. Each hit on a
// Regrid-backed tag represents one avoided Regrid API call.
model CacheHit {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  cacheTag  String   // e.g. 'parcel', 'neighbors', 'adjacent', 'terrain'
  hitCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, cacheTag])
  @@index([date])
}

model RandomParcelPool {
  id          String   @id @default(cuid())
  state       String   // MO, KS, IA, OK
  parcelId    String
  data        String   // JSON stringified parcel response object
  acreage     Float
  county      String
  createdAt   DateTime @default(now())
  served      Boolean  @default(false)  // true once served to a user

  @@index([state, served])
  @@index([state, acreage])
}

model ParcelPurchase {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  leadId          String?
  lead            Lead?    @relation(fields: [leadId], references: [id])
  parcelLat       Float
  parcelLng       Float
  parcelAddress   String?
  parcelAcreage   Float?
  stripeSessionId String?
  purchaseType    String   @default("hunt_plan")
  amount          Int      @default(1900)
  purchasedAt     DateTime @default(now())

  @@unique([userId, parcelLat, parcelLng])
  @@index([userId])
  @@index([leadId])
}

model SavedProperty {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  name            String
  type            String
  parcels         Json
  totalAcres      Float
  centroidLat     Float
  centroidLng     Float
  terrainScore    Int?
  primaryMovement String?
  funnelCount     Int?
  standCount      Int?
  bedAcres        Float?
  // Real terrain backbone verdict (3-state gate) — same source as map + report
  backboneState        String?
  backboneRank         Int?
  ridgeSpineCount      Int?
  saddleCrossings      Int?
  convergenceZoneCount Int?
  backboneComputedAt   DateTime?
  notes           String?
  shareId         String?  @unique @default(cuid())
  isShared        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  listings        Listing[]

  @@index([userId])
}

// ============================================================================
// Marketplace — additive Chunk 1.
//
// Listing is anchored to a SavedProperty (the user's certified hunt
// territory). The certification is the value prop.
//
// OPSEC: Listing intentionally has NO precise-location fields.
// County is the finest geographic grain. centroidLat/centroidLng on
// SavedProperty must NEVER copy onto Listing at any step.
// ============================================================================
model Listing {
  id                       String          @id @default(cuid())
  // FK -> SavedProperty (the hunt-report anchor for this listing).
  savedPropertyId          String
  // Drift tracking: the SavedProperty.updatedAt at the moment we snapshot.
  // Lets chunk 3 detect when the underlying analysis has been re-run and
  // prompt the owner to re-publish.
  savedPropertyUpdatedAt   DateTime?
  ownerUserId              String

  // Snapshot from SavedProperty at publish time (chunk 3 writes these;
  // chunk 1 just reserves the columns). All nullable for DRAFT.
  state                    String?         // 2-letter, e.g. "MO"
  county                   String?
  acres                    Float?          // from SavedProperty.totalAcres
  terrainScore             Int?            // from SavedProperty.terrainScore
  primaryMovement          String?         // from SavedProperty.primaryMovement
  bedAcres                 Float?          // from SavedProperty.bedAcres
  funnelCount              Int?            // from SavedProperty.funnelCount

  // Lease terms — null in DRAFT, required at PENDING_REVIEW (chunk 3)
  askingPriceMin           Int?            // USD/year, integer dollars
  askingPriceMax           Int?
  leaseType                LeaseType?
  huntersMax               Int?
  seasonAvailability       String[]        @default([])  // ["bow","rifle","muzzleloader","youth"]
  amenities                Json?           // { water, foodPlots, parking, lodging, atvAccess, electricity }

  // Listing content
  title                    String?         // optional; fall-back rendered as "{acres} ac in {county}, {state}"
  description              String?         @db.Text   // ~500 char cap, validated in app layer
  photos                   String[]        @default([])  // object-storage URLs, max 6, listings/ prefix

  // Public-safe Terrain Brain summary counts (populated at publish time)
  corridorCount            Int?            // # of classified flow corridors
  interceptCount           Int?            // # of convergence / intercept zones
  flowIndex                Int?            // Deer Flow Index 0-100, computed at publish time

  // Deer-flow snapshot — owner/lessee tier.
  // Populated at publish time from TerrainAnalysisCache.
  // JSON: { flowPrimary, flowSecondary, convergenceZones, parcelBounds }
  // OPSEC-safe field name: does NOT match /lat|lng|long|geom|polygon|address|coord/i
  terrainFlowSnapshot      String?         @db.Text

  // ── Phase 3: REAL backbone verdict (the honest engine's determination) ──
  // Populated at publish time and by the one-time backfill from the SAME
  // shared verdict the intel readout consults (metadata.backbone). Browse
  // sort/filter and the URL slug rank on THESE fields, never on terrainScore
  // (the retired v1 fabricated score). All nullable: a listing with no real
  // verdict yet (cache/compute miss) ranks as unranked (lowest).
  backboneState            String?         // 'confirmed' | 'marginal' | 'flat'
  backboneRank             Int?            // sortable: confirmed=2, marginal=1, flat=0; null = unranked
  ridgeSpineCount          Int?            // prominence-qualified traced ridge lines (metadata.backbone.networkLines)
  saddleCrossings          Int?            // saddle nodes on the backbone (ridge_saddle_count)
  convergenceZoneCount     Int?            // real convergence zones (metadata.stats.convergence_count)
  backboneComputedAt       DateTime?       // provenance: when the real verdict was last computed

  // Contact
  contactMethod            ContactMethod?
  contactEmail             String?
  contactPhone             String?

  // Lifecycle
  status                   ListingStatus   @default(DRAFT)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  publishedAt              DateTime?

  savedProperty            SavedProperty   @relation(fields: [savedPropertyId], references: [id])
  owner                    User            @relation(fields: [ownerUserId], references: [id])
  inquiries                Inquiry[]

  @@index([ownerUserId, status])
  @@index([state, status])
  @@index([status, backboneRank])
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  LEASED
  EXPIRED
  WITHDRAWN
}

enum LeaseType {
  ANNUAL
  SEASON_FULL
  RIFLE_ONLY
  BOW_ONLY
  YOUTH
  OTHER
}

enum ContactMethod {
  EMAIL_RELAY
  PHONE
  BOTH
}


// ─── Waitlist (Chunk 2 — FB landing pages) ─────────────────────────────────
// Captures intent from /lease-your-land and /find-a-lease landing pages
// before the public marketplace ships. No auth required — this is a
// pre-launch signup capture, not a user account.

model Waitlist {
  id              String         @id @default(cuid())
  side            WaitlistSide
  email           String
  name            String?
  state           String?        // 2-letter; landowners (single state)
  states          String[]       @default([])  // hunters (multiple regions of interest)
  acres           Float?         // landowners only, approximate
  maxBudgetUsd    Int?           // hunters only, USD/year
  seasonInterest  String[]       @default([])  // hunters only ("bow","rifle","muzzleloader","youth")
  groupSize       Int?           // hunters only
  source          String?        // free-text e.g. "fb_organic", "homepage_cta"
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  notes           String?        @db.Text
  createdAt       DateTime       @default(now())

  @@index([side, state])
  @@index([email])
}

enum WaitlistSide {
  LANDOWNER
  HUNTER
}


// ─── Inquiry (Chunk 4 — public inquiry form on PUBLISHED listings) ─────────
// Captured when a hunter submits the inquiry form on a public listing detail
// page. Email-relayed to landowner via lib/email.ts; hunter gets confirmation.
//
// OPSEC: This row stores hunter contact + free-text message. It does NOT
// store the listing's location any more precisely than the Listing already
// does (state + county only).

model Inquiry {
  id              String          @id @default(cuid())
  listingId       String
  listing         Listing         @relation(fields: [listingId], references: [id])

  // Optional link to a logged-in user. Captures userId at submission time
  // so accepted lessees can be granted full Terrain Brain access.
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  hunterEmail     String          // lowercased on write
  hunterName      String
  hunterPhone     String?
  preferredDates  String?         // free-text v1 (e.g. "First two weeks of November")
  partySize       Int             @default(1)
  message         String          @db.Text  // 20-2000 chars, validated at API

  status          InquiryStatus   @default(NEW)

  source          String?         // "listing_detail" | "find_a_lease" | etc.
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?

  // sha256(IP + INQUIRY_IP_SALT) — never raw IP. Used for rate-limit only.
  ipHash          String?

  createdAt       DateTime        @default(now())
  repliedAt       DateTime?
  closedAt        DateTime?
  acceptedAt      DateTime?

  @@index([listingId, status])
  @@index([hunterEmail])
  @@index([listingId, userId, status])
}

enum InquiryStatus {
  NEW
  REPLIED
  ACCEPTED
  CLOSED
}

model HuntingReport {
  id          String   @id @default(cuid())
  payload     Json
  ownerUserId String?
  owner       User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([ownerUserId])
}

// v4.0 — Per-parcel terrain analysis cache for Territory assembly
model TerrainAnalysisCache {
  id        String   @id @default(cuid())
  parcelId  String   @unique          // Regrid ll_uuid or synthetic ID
  lat       Float                     // Parcel centroid latitude
  lng       Float                     // Parcel centroid longitude
  acreage   Float    @default(0)
  data      String   @db.Text         // JSON: { layers, tieredCorridorData, ridgeSpineData, terrainFlowData, summary, provenance }
  version   Int      @default(1)      // Legacy write counter (kept for history)
  engineVersion String @default("legacy") // Terrain engine version this entry was computed with; read path filters on the current version
  createdAt DateTime @default(now())
  expiresAt DateTime                  // TTL (e.g., 7 days)

  @@index([lat, lng])
  @@index([expiresAt])
  @@index([engineVersion])
}

// v4.1 — Post-hunt outcome recording
model HuntSession {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcelId          String
  standLabel        String
  standCoordinates  Json                    // { lng, lat }
  standType         String                  // e.g. "Ridge Stand", "Saddle Crossing"
  terrainFeatures   Json                    // Full terrain context snapshot for ML
  windDirection     String
  rutPhase          String                  // early, rut, late
  groundMoisture    String                  // "Firm" or "Soft"
  moonPhase         String?
  huntStartTime     DateTime  @default(now())
  outcome           String?                 // saw_deer, harvested, scouted, no_activity
  outcomeRecordedAt DateTime?
  deerCount         Int?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([parcelId])
}

// v3.9.2 — "Hunt This" stand selection for the day
model StandSelection {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcelId        String                    // Regrid parcel ID or territory key
  standLng        Float
  standLat        Float
  standName       String
  terrainFeature  String                    // e.g. "Terrain Pinch Point", "Saddle Crossing"
  confidence      Int                       // 0-100 alignment score
  windDirection   String                    // N, NE, E, ...
  groundMoisture  String                    // "Firm" or "Soft"
  seasonPhase     String                    // early, rut, late
  huntDate        DateTime @db.Date         // calendar date of the hunt
  createdAt       DateTime @default(now())

  @@unique([userId, huntDate])              // one selection per user per day
  @@index([userId])
}

// Founding Property Signups — /listings landing page
model FoundingPropertySignup {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  firstName      String
  email          String
  state          String
  approxAcreage  String
  landownerType  String   // 'personal' or 'commercial'
  status         String   @default("new") // new, contacted, declined, onboarded
  notifiedClark  Boolean  @default(false)

  @@index([landownerType, status])
  @@index([email])
}

// Launch Waitlist — shown when founding cohort is full
model LaunchWaitlist {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  firstName String
  email     String
  state     String

  @@index([email])
}
// ─── County Deer Flow Rating (aggregated flow-by-area) ─────────────────────
// Precomputed county-level roll-up of per-parcel Terrain Brain flow signals.
// Powers the public "flow-by-area" view and the county flow-alerts signup.
//
// Source: TerrainAnalysisCache (per-parcel flow) joined to ParcelCache
// (county/state by lat/lng). Recomputed by scripts/compute-county-flow.ts.
//
// OPSEC: county is the FINEST grain stored here — never any lat/lng/parcel id.
model CountyFlowRating {
  id             String   @id @default(cuid())
  state          String   // 2-letter, e.g. "MO"
  county         String   // normalized Title Case, e.g. "Johnson"
  parcelCount    Int      @default(0)   // # analyzed parcels backing this score
  avgFlowIndex   Int      @default(0)   // 0-100 Deer Flow Index (raw mean of parcels)
  adjustedFlowIndex Int   @default(0)   // shrinkage-adjusted score (ranking + grade)
  limitedData    Boolean  @default(false) // true when parcelCount below reliability floor
  grade          String   @default("—") // A+ ... C-
  avgFunnelCount Float    @default(0)
  avgBedAcres    Float    @default(0)
  avgTopStand    Float    @default(0)   // avg top intercept/stand score
  highFlowCount  Int      @default(0)   // # parcels with flow index >= 75
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([state, county])
  @@index([state, avgFlowIndex])
  @@index([adjustedFlowIndex])
  @@index([highFlowCount])
}


// ─── Brick 1: Hunter Trust Profile + Owner Browse-and-Choose ───────────────
// The FIRST brick of the vetted-introduction marketplace. GATED behind
// TFP_HUNTER_PROFILES_OPEN (closed by default) — not public.
//
// CENTRAL GUARDRAIL: this is "certified-huntable for people", so it must not
// overclaim. Every credential carries an honest CredentialLevel and nothing
// more. For MVP there is NO 'VERIFIED' level in the enum at all, so nothing
// in the app *can* render "verified"/"screened"/"background-checked". A real
// third-party check slots in later by ADDING a level + provenance columns;
// the render function is the only thing that changes (no data migration).
//
// Reputation is a SHELL: there is no numeric trust score field. A new hunter
// renders honestly as "New — unproven", carried by disclosed creds/refs.
// completedLeaseCount is the future container the (deferred) review engine
// will fill via accepted Inquiries; it renders unproven while 0.
model HunterProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Disclosure ──
  groupSize             Int?          // typical party size
  hasKidsFamily         Boolean?      // kids / family along
  footprint             Footprint?    // day-hunt / tent / trailer / RV
  needsPowerHookup      Boolean?
  needsWaterHookup      Boolean?
  hasATV                Boolean?      // brings an ATV/UTV

  // ── Credentials (each an honest verification level; NO 'verified' for MVP) ──
  huntingLicense        CredentialLevel @default(NONE)
  hunterEd              CredentialLevel @default(NONE)
  liabilityInsurance    CredentialLevel @default(NONE)
  mdcPermits            CredentialLevel @default(NONE)

  // ── Safety gate — SELF-ATTESTATION, never a background check ──
  firearmAttestation    Boolean  @default(false)  // "I attest I have no firearm-related violations"
  firearmAttestationAt  DateTime?

  // ── References (optional). PII is NOT surfaced in Brick 1 browse — stored
  //    for future genuine-engagement reveal. Array of { name, relationship,
  //    contact, note }. ──
  references            Json?

  // ── Reputation shell — NO numeric score. Future review engine fills this. ──
  completedLeaseCount   Int      @default(0)

  // ── Bio ──
  bio                   String?  @db.Text  // freeform "who we are / how we hunt"

  // ── Visibility. A profile only appears in owner browse when visible == true
  //    AND firearmAttestation == true (the affirmative-claim hard gate). ──
  visible               Boolean  @default(true)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  shortlistedBy         HunterShortlist[]

  @@index([visible, firearmAttestation])
}

// Owner-choose flow for Brick 1 (browse + shortlist only; no messaging/review
// engine yet). A landowner shortlists a hunter in general (listingId null) or
// against a specific listing they own. When the deferred acceptance/review
// flow lands, an ACCEPTED Inquiry (already carries userId) becomes the join
// that unlocks a review of the hunter's profile — no rework needed here.
model HunterShortlist {
  id               String        @id @default(cuid())
  ownerUserId      String
  owner            User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  hunterProfileId  String
  hunterProfile    HunterProfile @relation(fields: [hunterProfileId], references: [id], onDelete: Cascade)
  listingId        String?       // optional: shortlisted against a specific listing
  note             String?
  createdAt        DateTime      @default(now())

  @@unique([ownerUserId, hunterProfileId, listingId])
  @@index([ownerUserId])
  @@index([hunterProfileId])
}

enum Footprint {
  DAY_HUNT
  TENT
  TRAILER
  RV
}

// Honest verification ceiling for MVP. DOCUMENT_ON_FILE is defined for the
// future (a credential-document uploader is NOT built in Brick 1, so this
// value is currently UNREACHABLE and never surfaced). 'VERIFIED' is
// deliberately absent until a real third-party check exists.
enum CredentialLevel {
  NONE
  SELF_ATTESTED
  DOCUMENT_ON_FILE
}